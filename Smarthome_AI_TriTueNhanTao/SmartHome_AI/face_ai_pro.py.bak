import csv
import cv2
import mediapipe as mp
import numpy as np
import pickle
import os
import time
import pygame
import random
from sklearn.svm import SVC
from sklearn.model_selection import train_test_split
from sklearn.metrics import accuracy_score, classification_report
from sklearn.calibration import CalibratedClassifierCV

DATA_FILE = "face_owner_data.pkl"
MODEL_FILE = "face_ocsvm_model.pkl"

mp_face_mesh = mp.solutions.face_mesh
face_mesh = mp_face_mesh.FaceMesh(max_num_faces=1, min_detection_confidence=0.4, min_tracking_confidence=0.4)


def get_face_features(rgb_frame):
    results = face_mesh.process(rgb_frame)
    if not results.multi_face_landmarks:
        return None, None

    landmarks = results.multi_face_landmarks[0].landmark
    coords = np.array([[lm.x, lm.y, lm.z] for lm in landmarks])

    core_indices = [33, 263, 1, 61, 291, 199, 4, 152, 10, 109]
    core_coords = coords[core_indices]

    base_dist = np.linalg.norm(coords[33] - coords[263])
    if base_dist == 0: base_dist = 1

    features = []
    for i in range(len(core_coords)):
        for j in range(i + 1, len(core_coords)):
            dist = np.linalg.norm(core_coords[i] - core_coords[j]) / base_dist
            features.append(dist)

    return np.array(features), landmarks


def calculate_ear(landmarks, eye_indices):
    p2_p6 = np.linalg.norm(np.array([landmarks[eye_indices[1]].x, landmarks[eye_indices[1]].y]) -
                           np.array([landmarks[eye_indices[5]].x, landmarks[eye_indices[5]].y]))
    p3_p5 = np.linalg.norm(np.array([landmarks[eye_indices[2]].x, landmarks[eye_indices[2]].y]) -
                           np.array([landmarks[eye_indices[4]].x, landmarks[eye_indices[4]].y]))
    p1_p4 = np.linalg.norm(np.array([landmarks[eye_indices[0]].x, landmarks[eye_indices[0]].y]) -
                           np.array([landmarks[eye_indices[3]].x, landmarks[eye_indices[3]].y]))
    ear = (p2_p6 + p3_p5) / (2.0 * p1_p4)
    return ear


def is_wearing_mask(landmarks):
    p_0 = np.array([landmarks[0].x, landmarks[0].y, landmarks[0].z])
    p_17 = np.array([landmarks[17].x, landmarks[17].y, landmarks[17].z])
    mouth_dist = np.linalg.norm(p_0 - p_17)

    if mouth_dist < 0.07:
        return True
    return False


def auto_collect_owner_data(name):
    print(f"\n[INFO] Dang thu thap Data e-KYC cho CHU NHA: {name}")
    print(">> He thong bat dau dinh danh. Vui long lam theo huong dan tren Camera.")
    time.sleep(2)

    cap = cv2.VideoCapture(0, cv2.CAP_DSHOW)
    features_list = []

    stages = [
        ("BUOC 1: NHIN THANG VAO CAMERA", 40),
        ("BUOC 2: TU TU QUAY MAT SANG TRAI", 40),
        ("BUOC 3: TU TU QUAY MAT SANG PHAI", 40)
    ]

    for stage_name, num_samples in stages:
        print(f"\n--- {stage_name} ---")

        start_time = time.time()
        while time.time() - start_time < 3:
            ret, frame = cap.read()
            if not ret: break
            frame = cv2.flip(frame, 1)
            frame = cv2.convertScaleAbs(frame, alpha=1.2, beta=40)

            overlay = frame.copy()
            cv2.rectangle(overlay, (0, 0), (frame.shape[1], frame.shape[0]), (0, 0, 0), -1)
            frame = cv2.addWeighted(overlay, 0.7, frame, 0.3, 0)

            remain_time = 3 - int(time.time() - start_time)
            cv2.putText(frame, stage_name, (20, 200), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 255), 2)
            cv2.putText(frame, f"Chuan bi sau: {remain_time}s", (20, 250), cv2.FONT_HERSHEY_SIMPLEX, 0.8,
                        (255, 255, 255), 2)

            cv2.imshow("Thu thap Data e-KYC", frame)
            cv2.waitKey(1)

        collected = 0
        while collected < num_samples:
            ret, frame = cap.read()
            if not ret: break
            frame = cv2.flip(frame, 1)
            frame = cv2.convertScaleAbs(frame, alpha=1.2, beta=40)

            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            features, _ = get_face_features(rgb_frame)

            if features is not None:
                features_list.append(features)
                collected += 1
                color = (0, 255, 0)
                status_text = f"{stage_name} ({collected}/{num_samples})"
            else:
                color = (0, 0, 255)
                status_text = "Khong thay mat! Hay dua mat vao khung hinh."

            cv2.putText(frame, status_text, (20, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.7, color, 2)

            progress = int((collected / num_samples) * 400)
            cv2.rectangle(frame, (20, 70), (20 + progress, 85), (0, 255, 0), -1)
            cv2.rectangle(frame, (20, 70), (420, 85), (255, 255, 255), 2)

            cv2.imshow("Thu thap Data e-KYC", frame)
            if cv2.waitKey(1) & 0xFF == ord('q'):
                cap.release()
                cv2.destroyAllWindows()
                return

    cap.release()
    cv2.destroyAllWindows()

    csv_filename = f"dataset_{name}.csv"
    with open(csv_filename, mode='w', newline='') as file:
        writer = csv.writer(file)
        writer.writerows(features_list)

    print(f"\nDa thu thap xong bo du lieu e-KYC.")


def generate_unknown_shield(owner_name):
    filename = f"dataset_{owner_name}.csv"
    if not os.path.exists(filename):
        print(f"LOI: Chua co du lieu cua {owner_name}! Hay quet mat truoc.")
        return

    print(f"\n[INFO] Dang phan tich khuon mat cua {owner_name} de tao khien ao...")

    X_owner = []
    with open(filename, mode='r') as file:
        reader = csv.reader(file)
        for row in reader:
            X_owner.append([float(val) for val in row])

    X_owner = np.array(X_owner)
    mean_face = np.mean(X_owner, axis=0)
    std_face = np.std(X_owner, axis=0)
    std_face = np.where(std_face == 0, 0.001, std_face)

    fake_features = []
    for _ in range(150):
        noise = np.random.uniform(3, 6, len(mean_face)) * std_face * np.random.choice([-1, 1], len(mean_face))
        fake_face = mean_face + noise
        fake_features.append(fake_face.tolist())

    with open("dataset_Unknown.csv", mode='w', newline='') as file:
        writer = csv.writer(file)
        writer.writerows(fake_features)

    print("Da tao xong tap du lieu Unknown.")


def train_svc_multi_class():
    X = []
    Y = []
    classes = []

    print("\n[INFO] Dang quet du lieu...")
    for filename in os.listdir("."):
        if filename.startswith("dataset_") and filename.endswith(".csv"):
            name = filename.replace("dataset_", "").replace(".csv", "")
            classes.append(name)

            with open(filename, mode='r') as file:
                reader = csv.reader(file)
                for row in reader:
                    X.append([float(val) for val in row])
                    Y.append(classes.index(name))

    if len(classes) < 2:
        print("Can it nhat 2 lop du lieu khac nhau de huan luyen.")
        return

    X = np.array(X)
    Y = np.array(Y)

    print(f"[INFO] Tim thay {len(classes)} thanh vien: {', '.join(classes)}")
    X_train, X_test, Y_train, Y_test = train_test_split(X, Y, test_size=0.2, random_state=42)
    print(f"[INFO] Bat dau huan luyen tren {len(X_train)} mau...")

    base_svm = SVC(kernel='rbf', gamma='scale')
    svm_model = CalibratedClassifierCV(base_svm, ensemble=False)
    svm_model.fit(X_train, Y_train)

    print("\n[INFO] Dang danh gia mo hinh...")
    Y_pred = svm_model.predict(X_test)
    acc = accuracy_score(Y_test, Y_pred)
    print(f"Do chinh xac tong (Accuracy): {acc * 100:.2f}%")
    print("\nBANG BAO CAO CHI TIET:")
    print(classification_report(Y_test, Y_pred, target_names=classes, zero_division=0))

    final_base_svm = SVC(kernel='rbf', gamma='scale')
    final_model = CalibratedClassifierCV(final_base_svm, ensemble=False)
    final_model.fit(X, Y)

    model_data = {"model": final_model, "classes": classes}
    with open(MODEL_FILE, "wb") as f:
        pickle.dump(model_data, f)

    print("Da luu mo hinh huan luyen.")


def run_smart_home():
    if not os.path.exists(MODEL_FILE):
        print("Chua co mo hinh duoc huan luyen.")
        return

    with open(MODEL_FILE, "rb") as f:
        model_data = pickle.load(f)
        svm_model = model_data["model"]

        if "classes" not in model_data:
            print("Mo hinh cu khong tuong thich. Vui long huan luyen lai.")
            return
        model_classes = model_data["classes"]

    print("\n[INFO] HE THONG BAO MAT DA KICH HOAT.")
    pygame.mixer.init()
    cap = cv2.VideoCapture(0, cv2.CAP_DSHOW)

    left_eye_indices = [362, 385, 386, 263, 374, 380]
    right_eye_indices = [33, 160, 158, 133, 153, 144]

    is_awake = False
    scan_timer = 0
    last_status = None
    secure_stage = 0
    challenge_frames = 0
    challenge_start_time = 0
    unknown_counter = 0
    owner_name = "Unknown"

    challenges = ["BLINK", "TURN_LEFT", "TURN_RIGHT", "OPEN_MOUTH"]
    current_challenge = None
    challenge_text_map = {
        "BLINK": "NHAY MAT LIEN TUC",
        "TURN_LEFT": "QUAY MAT SANG TRAI",
        "TURN_RIGHT": "QUAY MAT SANG PHAI",
        "OPEN_MOUTH": "HA MIENG TO"
    }

    while True:
        ret, frame = cap.read()
        if not ret: break

        frame = cv2.flip(frame, 1)
        frame = cv2.convertScaleAbs(frame, alpha=1.2, beta=40)

        if not is_awake:
            frame[:] = (30, 30, 30)
            cv2.putText(frame, "HE THONG DANG NGU (TIET KIEM PIN)", (50, 200), cv2.FONT_HERSHEY_SIMPLEX, 0.8,
                        (150, 150, 150), 2)
            cv2.putText(frame, ">> BAM PHIM 'SPACE' DE DANH THUC <<", (50, 250), cv2.FONT_HERSHEY_SIMPLEX, 0.8,
                        (0, 255, 255), 2)

            key = cv2.waitKey(1) & 0xFF
            if key == ord(' '):
                is_awake = True
                scan_timer = 900
                last_status = None
                secure_stage = 0
                challenge_frames = 0
                unknown_counter = 0
                owner_name = "Unknown"
                current_challenge = None
                print(">> He thong da thuc day, bat dau quet...")
            elif key == ord('q'):
                break
        else:
            scan_timer -= 1
            cv2.putText(frame, f"Thoi gian con lai: {scan_timer // 30}s", (20, 450), cv2.FONT_HERSHEY_SIMPLEX, 0.6,
                        (0, 255, 255), 2)

            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            features, landmarks = get_face_features(rgb_frame)

            if features is not None:
                if secure_stage == 0:
                    probabilities = svm_model.predict_proba([features])[0]
                    max_prob = np.max(probabilities)
                    best_match_index = np.argmax(probabilities)

                    cv2.putText(frame, f"Match: {max_prob * 100:.1f}%", (20, 190), cv2.FONT_HERSHEY_SIMPLEX, 0.6,
                                (255, 0, 255), 2)

                    if max_prob > 0.70:
                        owner_name = model_classes[best_match_index]
                        if owner_name == "Unknown":
                            unknown_counter += 1
                        else:
                            secure_stage = 1
                            challenge_start_time = time.time()
                            challenge_frames = 0
                            unknown_counter = 0
                            current_challenge = random.choice(challenges)
                            print(f">> Khop thuc the: {owner_name}. Kich hoat thu thach: {current_challenge}")
                    else:
                        unknown_counter += 1
                        cv2.putText(frame, "Dang soi mat, vui long dung yen...", (20, 50), cv2.FONT_HERSHEY_SIMPLEX,
                                    0.7, (0, 255, 255), 2)
                        if last_status != "SCANNING" and unknown_counter == 1:
                            if os.path.exists("dang_quet.mp3"):
                                pygame.mixer.music.load("dang_quet.mp3")
                                pygame.mixer.music.play()
                            last_status = "SCANNING"

                        if unknown_counter > 150:
                            cv2.putText(frame, "CANH BAO: NGUOI LA!", (20, 90), cv2.FONT_HERSHEY_SIMPLEX, 0.8,
                                        (0, 0, 255), 2)
                            cv2.putText(frame, ">> CUA KHOA <<", (20, 130), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255),
                                        2)
                            if last_status != "STRANGER":
                                if os.path.exists("bao_dong.mp3"):
                                    pygame.mixer.music.load("bao_dong.mp3")
                                    pygame.mixer.music.play()
                                last_status = "STRANGER"

                elif secure_stage == 1:
                    face_left = np.array([landmarks[234].x, landmarks[234].y])
                    face_right = np.array([landmarks[454].x, landmarks[454].y])
                    face_width = np.linalg.norm(face_left - face_right)

                    if face_width < 0.35:
                        cv2.putText(frame, ">> VUI LONG TIEN LAI GAN CAMERA <<", (20, 50), cv2.FONT_HERSHEY_SIMPLEX,
                                    0.7, (0, 0, 255), 2)
                        cv2.putText(frame, f"Do to mat: {face_width:.2f} (Can >= 0.35)", (20, 90),
                                    cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 255), 2)
                        if last_status != "TOO_FAR":
                            if os.path.exists("lai_gan.mp3"):
                                pygame.mixer.music.load("lai_gan.mp3")
                                pygame.mixer.music.play()
                            last_status = "TOO_FAR"
                    else:
                        eye_base = np.linalg.norm(np.array([landmarks[33].x, landmarks[33].y]) -
                                                  np.array([landmarks[263].x, landmarks[263].y]))
                        if eye_base == 0: eye_base = 1.0

                        dist_nose_left = abs(landmarks[4].x - landmarks[234].x)
                        dist_nose_right = abs(landmarks[4].x - landmarks[454].x)
                        turn_ratio = dist_nose_left / (dist_nose_right + 1e-6)

                        p_0 = np.array([landmarks[0].x, landmarks[0].y])
                        p_17 = np.array([landmarks[17].x, landmarks[17].y])
                        mouth_dist = np.linalg.norm(p_0 - p_17) / eye_base

                        ear_left = calculate_ear(landmarks, left_eye_indices)
                        ear_right = calculate_ear(landmarks, right_eye_indices)
                        avg_ear = (ear_left + ear_right) / 2.0

                        challenge_msg = challenge_text_map.get(current_challenge, "XAC THUC THUC THE VANG")
                        cv2.putText(frame, f"Hello {owner_name}!", (20, 40), cv2.FONT_HERSHEY_SIMPLEX, 0.7,
                                    (255, 145, 0), 2)
                        cv2.putText(frame, f">> {challenge_msg} <<", (20, 80), cv2.FONT_HERSHEY_SIMPLEX, 0.7,
                                    (0, 255, 255), 2)

                        challenge_passed = False

                        if current_challenge == "BLINK":
                            if avg_ear < 0.35:
                                challenge_passed = True
                        elif current_challenge == "TURN_LEFT":
                            if turn_ratio < 0.45:
                                challenge_passed = True
                        elif current_challenge == "TURN_RIGHT":
                            if turn_ratio > 2.2:
                                challenge_passed = True
                        elif current_challenge == "OPEN_MOUTH":
                            if mouth_dist > 0.55:
                                challenge_passed = True

                        if challenge_passed:
                            challenge_frames += 1
                            cv2.putText(frame, f"Dang thuc hien: {challenge_frames}/4", (20, 130),
                                        cv2.FONT_HERSHEY_SIMPLEX,
                                        0.7, (0, 255, 0), 2)
                        else:
                            challenge_frames = max(0, challenge_frames - 1)

                        if challenge_frames >= 4:
                            cv2.putText(frame, ">> HOAN THANH ANTI-SPOOFING! <<", (20, 130), cv2.FONT_HERSHEY_SIMPLEX,
                                        0.7, (0, 255, 0), 2)
                            secure_stage = 2
                            scan_timer = 90
                            challenge_frames = 0

                    if time.time() - challenge_start_time > 12:
                        print(">> Qua thoi gian thu thach! Chong gia mao kich hoat.")
                        secure_stage = 0
                        challenge_frames = 0
                        owner_name = "Unknown"
                        current_challenge = None

                elif secure_stage == 2:
                    cv2.putText(frame, f"Xin chao {owner_name}!", (20, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 0),
                                2)
                    cv2.putText(frame, "VERIFICATION SUCCESS! CUA DANG MO...", (20, 90), cv2.FONT_HERSHEY_SIMPLEX, 0.7,
                                (0, 255, 0), 2)

                    if last_status != "OWNER":
                        if os.path.exists("chao_sep.mp3"):
                            pygame.mixer.music.load("chao_sep.mp3")
                            pygame.mixer.music.play()
                        last_status = "OWNER"
                    cv2.imshow("Smart Home Security", frame)
                    cv2.waitKey(2500)

                    cap.release()
                    cv2.destroyAllWindows()

                    import sys
                    sys.exit(0)
            else:
                cv2.putText(frame, "Quet camera...", (20, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (200, 200, 200), 2)

            if scan_timer <= 0:
                is_awake = False
                secure_stage = 0
                owner_name = "Unknown"
                current_challenge = None
                print(">> He thong tu dong khoa va di ngu.")

            key = cv2.waitKey(1) & 0xFF
            if key == ord('q'): break

        cv2.imshow("Smart Home Security", frame)

    cap.release()
    cv2.destroyAllWindows()


if __name__ == "__main__":
    while True:
        print("\n=== BAO MAT SMART HOME HAI LOP LINH HOAT ===")
        print("1. Dang ky mat Chu Nha")
        print("2. Tao Khien Ao (Danh cho nguoi song 1 minh)")
        print("3. Train AI")
        print("4. Bat he thong an ninh (Da co Anti-Spoofing)")
        print("5. Thoat")

        choice = input("Chon tinh nang (1-5): ")
        if choice == '1':
            name = input("Nhap ten chu nha: ")
            auto_collect_owner_data(name)
        elif choice == '2':
            name = input("Nhap ten chu nha (de tao khien bao ve): ")
            generate_unknown_shield(name)
        elif choice == '3':
            train_svc_multi_class()
        elif choice == '4':
            run_smart_home()
        elif choice == '5':
            break